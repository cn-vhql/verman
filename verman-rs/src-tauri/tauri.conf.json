{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VerMan Rust",
  "version": "0.1.0",
  "identifier": "com.verman.rust",
  "build": {
    "beforeDevCommand": ".\\.tools\\trunk\\trunk.exe serve --port 1420",
    "beforeBuildCommand": ".\\.tools\\trunk\\trunk.exe build --release",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VerMan Rust",
        "label": "main",
        "width": 980,
        "height": 680,
        "minWidth": 860,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/Square150x150Logo.png",
      "icons/Square310x310Logo.png",
      "icons/StoreLogo.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
